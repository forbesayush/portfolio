# Copy this file to a new file named `.env` and fill in your details.
# DO NOT commit the `.env` file to GitHub. This file (.env.example) is safe to commit.

PORT=5000

# Put your NEW Telegram Bot Token here (after you revoke the hacked one)
TELEGRAM_BOT_TOKEN=YOUR_NEW_TOKEN_GOES_HERE

# Your Chat ID
TELEGRAM_CHAT_ID=6290094136

# Your LIVE website URL (for CORS security). e.g., https://yourusername.github.io
FRONTEND_URL=*
